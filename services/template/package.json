{
  "name": "template",
  "version": "0.1.0",
  "description": "",
  "main": "out/index.js",
  "type": "module",
  "scripts": {
    "set-token": "npm config set //registry.npmjs.org/:_authToken \"${NPM_TOKEN}\"",
    "start": "NODE_ENV=development nodemon --watch 'src/' --exec 'npm-run-all build-dev start-prod' -e ts",
    "start-prod": "node ./out/src/index.js",
    "lint": "eslint --print-config eslint.config.js && eslint '*/**/*.{ts,js}' --fix",
    "test": "jest",
    "prebuild": "npm run lint",
    "build": "tsc && node ./build-scripts/postbuild.cjs",
    "build-dev": "tsc && node ./build-scripts/postbuild.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/kyrix/template.git"
  },
  "author": "",
  "license": "AGPL-3.0-only",
  "homepage": "https://bitbucket.org/kyrix/template#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.49.0",
    "@hopara/http-server": "^1.13.0",
    "@hopara/logger": "^1.4.2",
    "@iarna/toml": "^2.2.5",
    "@types/pg": "^8.6.4",
    "ajv": "^8.18.0",
    "awilix": "^12.0.5",
    "axios": "^1.15.0",
    "config": "^3.3.7",
    "lodash": "~4.18.1",
    "mime-types": "^2.1.35",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@hopara/eslint-config": "^3.0.16",
    "@types/config": "^0.0.41",
    "@types/jest": "^27.4.0",
    "@types/lodash": "^4.17.20",
    "@types/mime-types": "^2.1.4",
    "@typescript-eslint/eslint-plugin": "^5.10.1",
    "@typescript-eslint/parser": "^5.10.1",
    "eslint": "^9.23.0",
    "jest": "^26.1.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^26.1.3",
    "typescript": "^5.8.2"
  },
  "packageManager": "yarn@4.7.0"
}

#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]
*.egg-info/

# Log files
*.log

# Package files
*.jar

# Maven
target/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large resources files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

*_trial_marker*

temp/

_trial_temp/
*.env
*-checkpoint.ipynb
_trial_temp.lock
/api/icon/smart_search/wandb/
/api/wandb/
/tests/tmp/
/api/icon/smart_search/validation_report.html
/api/icon/smart_search/*.dump
/tests/test-results/unittest.xml

.coverage
.vscode

.import_linter_cache/

local_storage/

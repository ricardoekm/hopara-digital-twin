{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "out",
    "strict": true,
    "strictPropertyInitialization": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "lib": [
      "es2021"
    ],
    "target": "es2016",
    "module": "node16",
    "moduleResolution": "nodenext"
  }
}

{
   // Use IntelliSense to learn about possible attributes.
   // Hover to view descriptions of existing attributes.
   // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
   "version": "0.2.0",
   "configurations": [     
      {
         "name": "Launch",
         "type": "node",
         "request": "launch",
         "cwd": "${workspaceFolder}",
         "runtimeExecutable": "yarn",
         "runtimeArgs": ["start"]
      },
      {
         "name": "Schema",
         "type": "node",
         "request": "launch",
         "cwd": "${workspaceFolder}",
         "runtimeExecutable": "yarn",
         "runtimeArgs": ["build-schemas"]
      },
      {
         "name": "Unit Test",
         "type": "node",
         "request": "launch",
         "cwd": "${workspaceFolder}",
         "runtimeExecutable": "yarn",
         "runtimeArgs": ["unit-test"]
      },
      {
         "name": "Integration Test",
         "type": "node",
         "request": "launch",
         "cwd": "${workspaceFolder}",
         "runtimeExecutable": "yarn",
         "runtimeArgs": ["integration-test"]
      },
      {
         "type": "node",
         "request": "launch",
         "name": "File",
         "program": "${file}",
         "args": [
            "--trace-warnings"
         ],
         "preLaunchTask": "tsc: build - tsconfig.json",
         "outFiles": ["${workspaceFolder}/out/**/*.js"]
     }
   ]
}
{
  "name": "@hopara/visualization",
  "version": "0.59.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "set-token": "npm config set //registry.npmjs.org/:_authToken \"${NPM_TOKEN}\"",
    "start": "NODE_ENV=development nodemon --watch 'src/' --exec 'npm-run-all build start-js' -e ts",
    "build": "tsc --build",
    "start-js": "node ./out/src/index.js",
    "lint": "eslint --print-config eslint.config.js && eslint 'src/**/*.{ts,js}' --fix",
    "unit-test": "jest",
    "test": "npm-run-all lint unit-test integration-test",
    "integration-test": "node node_modules/.bin/jest --config=jest.integration.config.js",
    "migrate": "tsx src/migrate.ts",
    "build-schemas": "npm-run-all compile-schemas sanitize-schemas",
    "build-docs": "tsx src/build/generate-docs.ts",
    "compile-schemas": "mkdir -p out/schemas && ts-json-schema-generator -f tsconfig.json -p src/index.ts -t VisualizationSpec --additional-properties --no-type-check --no-ref-encode > out/schemas/schema.json",
    "sanitize-schemas": "tsx src/sanitize-schema.ts",
    "pre-commit": "npm-run-all build-schemas build-docs test",
    "layer-templates": "tsx src/layer-template/image-generator.ts"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@hopara/eslint-config": "^3.0.14",
    "@types/config": "0.0.36",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.14.179",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.13",
    "@types/pg": "^7.14.4",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^9.23.0",
    "jest": "^27.5.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.1.3",
    "ts-jest": "^27.1.4",
    "ts-json-schema-generator": "^1.3.0",
    "tsx": "^4.19.3",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "@hopara/http-server": "^1.13.0",
    "@hopara/logger": "^1.4.2",
    "@hopara/schema-validator": "^0.1.6",
    "ajv": "^8.18.0",
    "awilix": "^4.3.4",
    "axios": "^1.15.0",
    "case": "^1.6.3",
    "change-case": "^4.1.2",
    "config": "^3.3.1",
    "dayjs": "^1.11.3",
    "eslint-find-rules": "^4.1.0",
    "gdeep-replace": "^0.1.0",
    "glob": "^13.0.6",
    "glob-promise": "^6.0.7",
    "knex": "^3.1.0",
    "lodash": "~4.18.1",
    "pg": "^8.3.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "semver": "^7.7.1",
    "serialize-error": "^11.0.3",
    "slugify": "^1.6.5",
    "typeorm": "^0.3.6",
    "uuid": "^14.0.0",
    "vscode-json-languageservice": "^4.2.1"
  },
  "packageManager": "yarn@4.7.0"
}
